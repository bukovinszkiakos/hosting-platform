# Internal project handoff / session notes — never published.
PROJECT_HANDOFF_*.md

# Real (filled-in) Kubernetes config/secret manifests must never be committed.
# Use the bootstrap script (scripts/deployment/bootstrap-config.sh) or, if copying
# a template, keep only the *.example.yaml files in Git. See docs/16-deployment.md
# "Configuration and secrets bootstrap".
k8s/secrets/*.yaml
!k8s/secrets/*.example.yaml
k8s/base/configmap.yaml

# Machine-managed by scripts/deployment/up.sh: holds the discovered ALB hostname
# for the two-phase platform-CloudFront apply. Terraform auto-loads *.auto.tfvars.
# Never committed — the human-edited terraform.tfvars stays the readable source.
terraform/environments/*/alb_dns_name.auto.tfvars

# Local Claude Code settings — machine-specific, not shared.
.claude/settings.local.json

# OS / editor cruft.
.DS_Store
